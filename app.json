  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Health status changed",
          "nl": "Statuswijziging",
          "de": "Zustand hat sich geändert",
          "fr": "L'état a changé",
          "es": "El estado ha cambiado",
          "it": "Lo stato è cambiato"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "tokens": [
          {
            "name": "health",
            "type": "string",
            "title": {
              "en": "Health",
              "nl": "Status",
              "de": "Zustand",
              "fr": "État",
              "es": "Estado",
              "it": "Stato"
            },
            "example": "warning"
          }
        ],
        "id": "health_changed"
      },
      {
        "title": {
          "en": "Health became critical",
          "nl": "Status werd kritiek",
          "de": "Zustand wurde kritisch",
          "fr": "L'état est devenu critique",
          "es": "El estado se volvió crítico",
          "it": "Lo stato è diventato critico"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "health_critical"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Health !{{is|isn't}} OK",
          "nl": "Status !{{is|is niet}} OK",
          "de": "Zustand !{{ist|ist nicht}} OK",
          "fr": "L'état !{{est|n'est pas}} OK",
          "es": "El estado !{{está|no está}} OK",
          "it": "Lo stato !{{è|non è}} OK"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "health_is_ok"
      },
      {
        "title": {
          "en": "Server !{{is|isn't}} powered on",
          "nl": "Server !{{is|is niet}} ingeschakeld",
          "de": "Server !{{ist|ist nicht}} eingeschaltet",
          "fr": "Le serveur !{{est|n'est pas}} allumé",
          "es": "El servidor !{{está|no está}} encendido",
          "it": "Il server !{{è|non è}} acceso"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "is_on"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Force restart",
          "nl": "Geforceerd herstarten",
          "de": "Neustart erzwingen",
          "fr": "Forcer le redémarrage",
          "es": "Forzar reinicio",
          "it": "Forza riavvio"
        },
        "hint": {
          "en": "Restarts the server immediately without shutting down the operating system. Unsaved data may be lost.",
          "nl": "Herstart de server direct zonder het besturingssysteem af te sluiten. Niet-opgeslagen gegevens kunnen verloren gaan.",
          "de": "Startet den Server sofort neu, ohne das Betriebssystem herunterzufahren. Nicht gespeicherte Daten können verloren gehen.",
          "fr": "Redémarre immédiatement le serveur sans arrêter le système d'exploitation. Les données non enregistrées peuvent être perdues.",
          "es": "Reinicia el servidor de inmediato sin apagar el sistema operativo. Se pueden perder los datos no guardados.",
          "it": "Riavvia immediatamente il server senza arrestare il sistema operativo. I dati non salvati potrebbero andare persi."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "cold_boot"
      },
      {
        "title": {
          "en": "Force power off",
          "nl": "Geforceerd uitschakelen",
          "de": "Ausschalten erzwingen",
          "fr": "Forcer l'extinction",
          "es": "Forzar apagado",
          "it": "Forza spegnimento"
        },
        "hint": {
          "en": "Cuts power immediately without shutting down the operating system, like holding the power button. Unsaved data may be lost.",
          "nl": "Schakelt de stroom direct uit zonder het besturingssysteem af te sluiten, zoals het ingedrukt houden van de aan/uit-knop. Niet-opgeslagen gegevens kunnen verloren gaan.",
          "de": "Trennt sofort die Stromversorgung, ohne das Betriebssystem herunterzufahren – wie langes Drücken des Netzschalters. Nicht gespeicherte Daten können verloren gehen.",
          "fr": "Coupe immédiatement l'alimentation sans arrêter le système d'exploitation, comme un appui long sur le bouton d'alimentation. Les données non enregistrées peuvent être perdues.",
          "es": "Corta la alimentación de inmediato sin apagar el sistema operativo, como mantener pulsado el botón de encendido. Se pueden perder los datos no guardados.",
          "it": "Toglie immediatamente l'alimentazione senza arrestare il sistema operativo, come tenere premuto il pulsante di accensione. I dati non salvati potrebbero andare persi."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "force_off"
      },
      {
        "title": {
          "en": "Shut down",
          "nl": "Afsluiten",
          "de": "Herunterfahren",
          "fr": "Éteindre",
          "es": "Apagar",
          "it": "Spegni"
        },
        "hint": {
          "en": "Asks the operating system to shut down safely, then powers off.",
          "nl": "Vraagt het besturingssysteem om veilig af te sluiten en schakelt daarna uit.",
          "de": "Fordert das Betriebssystem auf, sicher herunterzufahren, und schaltet dann aus.",
          "fr": "Demande au système d'exploitation de s'arrêter en toute sécurité, puis coupe l'alimentation.",
          "es": "Pide al sistema operativo que se apague de forma segura y después corta la alimentación.",
          "it": "Chiede al sistema operativo di arrestarsi in modo sicuro, quindi spegne il server."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "graceful_shutdown"
      },
      {
        "title": {
          "en": "Turn on",
          "nl": "Inschakelen",
          "de": "Einschalten",
          "fr": "Allumer",
          "es": "Encender",
          "it": "Accendi"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "turn_on"
      },
      {
        "title": {
          "en": "Restart",
          "nl": "Herstarten",
          "de": "Neustart",
          "fr": "Redémarrer",
          "es": "Reiniciar",
          "it": "Riavvia"
        },
        "hint": {
          "en": "Asks the operating system to shut down safely, then starts the server again.",
          "nl": "Vraagt het besturingssysteem om veilig af te sluiten en start de server daarna opnieuw.",
          "de": "Fordert das Betriebssystem auf, sicher herunterzufahren, und startet den Server anschließend neu.",
          "fr": "Demande au système d'exploitation de s'arrêter en toute sécurité, puis redémarre le serveur.",
          "es": "Pide al sistema operativo que se apague de forma segura y después reinicia el servidor.",
          "it": "Chiede al sistema operativo di arrestarsi in modo sicuro, quindi riavvia il server."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "warm_reset"
      }
    ]
  },
