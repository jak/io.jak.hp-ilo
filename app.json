{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "io.jak.hp-ilo",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "HP iLO"
  },
  "description": {
    "en": "Manage and monitor HPE servers via the iLO Redfish API"
  },
  "category": [
    "tools"
  ],
  "brandColor": "#01A982",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "jak",
    "email": "191585+jak@users.noreply.github.com"
  },
  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Health status changed"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "tokens": [
          {
            "name": "health",
            "type": "string",
            "title": {
              "en": "Health"
            },
            "example": "warning"
          }
        ],
        "id": "health_changed"
      },
      {
        "title": {
          "en": "Health became critical"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "health_critical"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Health !{{is|isn't}} OK"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "health_is_ok"
      },
      {
        "title": {
          "en": "Server !{{is|isn't}} powered on"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "is_on"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Cold boot (force restart)"
        },
        "titleFormatted": {
          "en": "Cold boot (force restart) [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "cold_boot"
      },
      {
        "title": {
          "en": "Force power off"
        },
        "titleFormatted": {
          "en": "Force power off [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "force_off"
      },
      {
        "title": {
          "en": "Graceful shutdown"
        },
        "titleFormatted": {
          "en": "Graceful shutdown [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "graceful_shutdown"
      },
      {
        "title": {
          "en": "Turn on"
        },
        "titleFormatted": {
          "en": "Turn on [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "turn_on"
      },
      {
        "title": {
          "en": "Restart (warm)"
        },
        "titleFormatted": {
          "en": "Restart (warm) [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "id": "warm_reset"
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "HPE Server (iLO)"
      },
      "class": "other",
      "capabilities": [
        "onoff",
        "measure_power",
        "measure_temperature",
        "measure_temperature.cpu",
        "measure_fan_speed",
        "ilo_health"
      ],
      "capabilitiesOptions": {
        "onoff": {
          "title": {
            "en": "Power"
          }
        },
        "measure_temperature": {
          "title": {
            "en": "Inlet temperature"
          }
        },
        "measure_temperature.cpu": {
          "title": {
            "en": "CPU temperature"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/server/assets/images/small.png",
        "large": "/drivers/server/assets/images/large.png",
        "xlarge": "/drivers/server/assets/images/xlarge.png"
      },
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Connection"
          },
          "children": [
            {
              "id": "host",
              "type": "text",
              "label": {
                "en": "Host / IP"
              },
              "value": ""
            },
            {
              "id": "allow_self_signed",
              "type": "checkbox",
              "label": {
                "en": "Allow self-signed certificate"
              },
              "value": true,
              "hint": {
                "en": "iLO ships with a self-signed certificate. Disable only if you installed a trusted certificate."
              }
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Polling"
          },
          "children": [
            {
              "id": "poll_interval",
              "type": "number",
              "label": {
                "en": "Poll interval (seconds)"
              },
              "value": 30,
              "min": 10,
              "max": 3600,
              "step": 5,
              "units": {
                "en": "s"
              }
            }
          ]
        }
      ],
      "pair": [
        {
          "id": "login"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "server"
    }
  ],
  "capabilities": {
    "ilo_health": {
      "type": "enum",
      "title": {
        "en": "Health"
      },
      "uiComponent": "sensor",
      "getable": true,
      "setable": false,
      "values": [
        {
          "id": "ok",
          "title": {
            "en": "OK"
          }
        },
        {
          "id": "warning",
          "title": {
            "en": "Warning"
          }
        },
        {
          "id": "critical",
          "title": {
            "en": "Critical"
          }
        }
      ]
    },
    "measure_fan_speed": {
      "type": "number",
      "title": {
        "en": "Fan speed"
      },
      "uiComponent": "sensor",
      "getable": true,
      "setable": false,
      "units": {
        "en": "%"
      },
      "min": 0,
      "max": 100,
      "decimals": 0,
      "insights": true,
      "icon": "/assets/fan.svg"
    }
  }
}