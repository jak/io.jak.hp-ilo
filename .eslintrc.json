{
  "extends": "athom/homey-app",
  "ignorePatterns": ["test/", ".homeybuild/", "node_modules/"],
  "rules": {
    "node/no-missing-import": ["error", { "allowModules": ["homey"], "tryExtensions": [".js", ".ts", ".json", ".node"] }]
  },
  "overrides": [
    {
      "files": ["lib/**/*.ts", "test/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off"
      }
    }
  ]
}
